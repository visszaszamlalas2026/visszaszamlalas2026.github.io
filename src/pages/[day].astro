---
import { CONTENT_COLLECTION, DATE_FORMAT, endDate, startDate } from "../consts";
import { getEntry, getCollection } from "astro:content";
import "../styles/global.css";
import dayjs from "dayjs";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  return (await getCollection(CONTENT_COLLECTION)).map((entry) => ({
    params: {
      day: entry.id,
    },
  }));
}

const { day } = Astro.params;
const entry = await getEntry(CONTENT_COLLECTION, day);

const allDayImages = import.meta.glob<{ default: ImageMetadata }>(
  "/gdrive/*.jpg",
);
const thisDayImage = allDayImages[`/gdrive/${day}.jpg`];

const daysLeft = endDate.diff(dayjs(day, DATE_FORMAT), "day");
const caseCount = endDate.diff(startDate, "day") - daysLeft;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Visszaszámlálás 2026</title>
  </head>
  <body>
    <img src="/bg.jpg" id="background" />
    <div class="mx-auto w-full md:w-2xl px-4 mt-4">
      <a href="/">
        <h3 class="text-left">&laquo; Visszaszámlálás 2026</h3>
      </a>
      <h2 class="text-left">
        {daysLeft} nap a választásokig, {caseCount}. ügy
      </h2>
      <h1 class="text-5xl my-8">{entry?.data.title}</h1>
      <Image
        class="w-full"
        src={thisDayImage()}
        alt={entry?.data.title}
        width="700"
      />
      <div class="content">
        {entry?.data.content.map((p: string) => <p>{p}</p>)}
      </div>
      <a href="/" class="goback"> &laquo; Vissza a naptárhoz </a>
    </div>
    <p class="footer">
      Copyright &copy; 2026 |
      <a
        href="https://github.com/visszaszamlalas2026/visszaszamlalas2026.github.io"
        >GitHub repo</a
      >
      <!-- ^ wtf is this auto-formatting lol -->
      | <a href="https://ahang.hu/">aHang</a>
    </p>
  </body>
</html>
